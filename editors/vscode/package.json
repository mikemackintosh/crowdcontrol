{
  "name": "crowdcontrol-policy-language",
  "displayName": "CrowdControl Policy Language",
  "description": "Syntax highlighting and language support for .cc CrowdControl policy files",
  "version": "0.1.0",
  "publisher": "mikemackintosh",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikemackintosh/crowdcontrol"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:crowdcontrol"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "crowdcontrol",
        "aliases": ["CrowdControl", "crowdcontrol", "cc"],
        "extensions": [".cc"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "crowdcontrol",
        "scopeName": "source.crowdcontrol",
        "path": "./syntaxes/crowdcontrol.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "CrowdControl Policy Language",
      "properties": {
        "crowdcontrol.lsp.path": {
          "type": "string",
          "default": "cc-lsp",
          "description": "Path to the cc-lsp binary"
        },
        "crowdcontrol.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the CrowdControl language server for diagnostics and completion"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0",
    "vscode-languageclient": "^9.0.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  }
}
