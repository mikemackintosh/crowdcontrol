{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CrowdControl Policy Language",
  "scopeName": "source.crowdcontrol",
  "patterns": [
    { "include": "#comments" },
    { "include": "#rules" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.hash.crowdcontrol",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.crowdcontrol",
          "match": "//.*$"
        }
      ]
    },
    "rules": {
      "patterns": [
        {
          "name": "meta.rule.crowdcontrol",
          "begin": "\\b(forbid|warn|permit)\\b\\s*(\"[^\"]*\")\\s*(\\{)",
          "beginCaptures": {
            "1": { "name": "keyword.control.rule.crowdcontrol" },
            "2": { "name": "entity.name.function.crowdcontrol" },
            "3": { "name": "punctuation.definition.block.begin.crowdcontrol" }
          },
          "end": "(\\})",
          "endCaptures": {
            "1": { "name": "punctuation.definition.block.end.crowdcontrol" }
          },
          "patterns": [
            { "include": "#comments" },
            { "include": "#metadata" },
            { "include": "#message" },
            { "include": "#unless-clause" },
            { "include": "#domain-primitives" },
            { "include": "#quantifiers" },
            { "include": "#not-operator" },
            { "include": "#count-aggregate" },
            { "include": "#field-condition" },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#booleans" },
            { "include": "#operators" },
            { "include": "#or-operator" },
            { "include": "#lists" }
          ]
        }
      ]
    },
    "metadata": {
      "patterns": [
        {
          "match": "\\b(description|owner|link)\\b\\s*(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.other.metadata.crowdcontrol" },
            "2": { "name": "string.quoted.double.crowdcontrol" }
          }
        }
      ]
    },
    "message": {
      "patterns": [
        {
          "match": "\\b(message)\\b\\s*(\")",
          "captures": {
            "1": { "name": "keyword.other.message.crowdcontrol" },
            "2": { "name": "string.quoted.double.begin.crowdcontrol" }
          }
        },
        {
          "name": "meta.message-string.crowdcontrol",
          "begin": "(?<=\\bmessage\\b\\s)\"",
          "beginCaptures": {
            "0": { "name": "string.quoted.double.begin.crowdcontrol" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "string.quoted.double.end.crowdcontrol" }
          },
          "patterns": [
            {
              "name": "variable.other.interpolation.crowdcontrol",
              "match": "\\{[^}]+\\}"
            },
            {
              "name": "string.quoted.double.crowdcontrol",
              "match": "[^\"{}]+"
            }
          ]
        }
      ]
    },
    "unless-clause": {
      "patterns": [
        {
          "name": "keyword.control.unless.crowdcontrol",
          "match": "\\bunless\\b"
        }
      ]
    },
    "domain-primitives": {
      "patterns": [
        {
          "match": "\\b(author)\\b\\s+\\b(in)\\b\\s+\\b(team)\\b\\s*(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.other.author.crowdcontrol" },
            "2": { "name": "keyword.operator.in.crowdcontrol" },
            "3": { "name": "keyword.other.team.crowdcontrol" },
            "4": { "name": "string.quoted.double.crowdcontrol" }
          }
        },
        {
          "match": "\\b(author)\\b\\s+\\b(in)\\b",
          "captures": {
            "1": { "name": "keyword.other.author.crowdcontrol" },
            "2": { "name": "keyword.operator.in.crowdcontrol" }
          }
        },
        {
          "match": "\\b(approved_by)\\b\\s+\\b(team)\\b\\s*(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.other.approved-by.crowdcontrol" },
            "2": { "name": "keyword.other.team.crowdcontrol" },
            "3": { "name": "string.quoted.double.crowdcontrol" }
          }
        },
        {
          "match": "\\b(label)\\b\\s*(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.other.label.crowdcontrol" },
            "2": { "name": "string.quoted.double.crowdcontrol" }
          }
        }
      ]
    },
    "quantifiers": {
      "patterns": [
        {
          "match": "\\b(any|all)\\b",
          "name": "keyword.operator.quantifier.crowdcontrol"
        }
      ]
    },
    "not-operator": {
      "patterns": [
        {
          "match": "\\bnot\\b",
          "name": "keyword.operator.not.crowdcontrol"
        }
      ]
    },
    "or-operator": {
      "patterns": [
        {
          "match": "\\bor\\b",
          "name": "keyword.operator.or.crowdcontrol"
        }
      ]
    },
    "count-aggregate": {
      "patterns": [
        {
          "match": "\\b(count)\\s*(\\()",
          "captures": {
            "1": { "name": "support.function.count.crowdcontrol" },
            "2": { "name": "punctuation.paren.open.crowdcontrol" }
          }
        }
      ]
    },
    "field-condition": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*)\\b(?=\\s*(?:==|!=|<=|>=|<|>|\\bin\\b|\\bmatches\\b))",
          "name": "variable.other.field.crowdcontrol"
        },
        {
          "match": "\\b(in|matches)\\b",
          "name": "keyword.operator.comparison.crowdcontrol"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.crowdcontrol",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.crowdcontrol",
              "match": "\\\\."
            },
            {
              "name": "variable.other.interpolation.crowdcontrol",
              "match": "\\{[^}]+\\}"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.crowdcontrol",
          "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.crowdcontrol",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.crowdcontrol",
          "match": "==|!=|<=|>=|<|>"
        }
      ]
    },
    "lists": {
      "patterns": [
        {
          "name": "meta.list.crowdcontrol",
          "begin": "\\[",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.list.begin.crowdcontrol" }
          },
          "end": "\\]",
          "endCaptures": {
            "0": { "name": "punctuation.definition.list.end.crowdcontrol" }
          },
          "patterns": [
            { "include": "#strings" },
            { "include": "#numbers" },
            {
              "name": "punctuation.separator.comma.crowdcontrol",
              "match": ","
            }
          ]
        }
      ]
    }
  }
}
