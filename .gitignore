# Binaries
bin/
*.exe
*.dll
*.so
*.dylib

# Root-level Go build outputs (go build ./cmd/cc drops the binary here)
/cc
/cc-lsp
/cc-test
# Never commit a bare 'go' file — it was added by accident once
/go

# WASM build artifacts for the docs playground — built by
# .github/workflows/pages.yml on every deploy, not checked in.
docs/assets/wasm/cc.wasm
docs/assets/wasm/wasm_exec.js

# Zed dev extension staging — produced by scripts/install-zed-extension.sh
/.zed-dev-extension/

# Rust build output (Zed extension) — Cargo.lock IS tracked so
# the extension is reproducible for anyone building from source.
editors/zed/target/

# Test
*.test
*.out
coverage.txt

# Go workspace
go.work
go.work.sum

# Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Language-specific build artifacts
# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# Node / TypeScript
node_modules/
*.tsbuildinfo

# Ruby
*.gem
.bundle/
vendor/bundle

# Kotlin / JVM
*.class
target/
.gradle/
build/

# PHP
vendor/
composer.lock
